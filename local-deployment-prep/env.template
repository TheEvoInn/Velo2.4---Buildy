# VELO 2.0 Local Environment Template

# --- SYSTEM CORE ---
APP_ENV=local
APP_ID=velo-local-001
DEBUG=true
PORT=3000

# --- DATABASE ---
# For local PostgreSQL
DATABASE_URL=postgresql://velo:password@localhost:5432/velo_db
# For local SQLite fallback
# DATABASE_URL=sqlite://./data/db/velo.sqlite

# --- LOCAL AI ENGINE ---
# Local LLM API (Ollama default)
LOCAL_AI_ENDPOINT=http://localhost:11434
LOCAL_AI_MODEL=llama3:8b
# LM Studio fallback
# LOCAL_AI_ENDPOINT=http://localhost:1234/v1

# --- STORAGE ---
STORAGE_ROOT=./data/storage
UPLOAD_LIMIT_MB=50

# --- CONTINUITY & OFFLINE ---
OFFLINE_MODE=true
FREE_FIRST_ONLY=true
MIGRATION_ACTIVE=false

# --- SECURITY ---
# Replace with generated secrets during local setup
JWT_SECRET=placeholder_generate_new_on_install
ENCRYPTION_KEY=placeholder_generate_new_on_install

# --- LOGGING ---
LOG_LEVEL=info
LOG_PATH=./logs/system.log
BLACK_BOX_PATH=./logs/blackbox.log

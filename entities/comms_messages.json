

{
  "name": "CommsMessage",
  "description": "Records of messages sent or drafted",
  "properties": {
    "recipient": { "type": "string", "description": "Recipient email address" },
    "subject": { "type": "string", "description": "Message subject" },
    "body_html": { "type": "string", "description": "Message body" },

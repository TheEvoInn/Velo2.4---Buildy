    "template_id": { "type": "string", "description": "Reference to the template used" },
    "department": { "type": "string", "description": "Originating department" },
    "sent_at": { "type": "string", "description": "Timestamp when sent" },
    "failure_reason": { "type": "string", "description": "Error details if failed" }
  }
}
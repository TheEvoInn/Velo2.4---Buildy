
{
  "name": "GalaxyOpportunityFeed",
  "description": "Normalized opportunity data before department routing",
  "properties": {
    "run_id": { "type": "string", "description": "Reference to the scanner run" },
    "department": { "type": "string", "description": "Target department" },
    "source_name": { "type": "string", "description": "Name of origin source" },
    "title": { "type": "string", "description": "Headline of the opportunity" },
    "edited_title": { "type": "string", "description": "User-edited headline" },
    "summary": { "type": "string", "description": "Detailed description" },
    "edited_summary": { "type": "string", "description": "User-edited description" },
    "reviewer_notes": { "type": "string", "description": "Notes from the reviewer" },
    "opportunity_type": { "type": "string", "description": "e.g. gig, token-signal, niche-trend" },
    "target_customer_or_asset": { "type": "string", "description": "Entity or asset name" },
    "confidence_score": { "type": "number", "description": "Internal match confidence" },
    "skill_match_score": { "type": "number", "description": "Profile match score 0-100 from readiness evaluation" },
    "match_breakdown": { "type": "array", "description": "Match quality detail strings (e.g. 4/7 skills, 3 service keywords)", "items": { "type": "string" } },
    "risk_level": { "type": "string", "description": "low, medium, high" },
    "routing_status": { "type": "string", "description": "pending, routed, ignored, archived" },
    "authorization_status": { "type": "string", "description": "awaiting_review, authorized, rejected" },
    "dry_run_passed": { "type": "boolean", "description": "Whether a dry run was successful" },
    "linked_department_record_id": { "type": "string", "description": "ID of the record in the target department entity" },
    "linked_mission_id": { "type": "string", "description": "ID of the review mission" },
    "source_url": { "type": "string", "description": "Direct link to the original post" },
    "payout_text": { "type": "string", "description": "Payout amount or range as text" },
    "payout_min": { "type": "number", "description": "Minimum payout value" },
    "payout_max": { "type": "number", "description": "Maximum payout value" },
    "estimated_time": { "type": "string", "description": "Estimated time to complete" },
    "requirements": { "type": "string", "description": "Requirements for the work" },
    "steps": { "type": "string", "description": "Steps involved in the work" },
    "skill_level": { "type": "string", "description": "Required skill level" },
    "autopilot_compatibility": { "type": "string", "description": "high, medium, low, manual" },
    "identity_verification_required": { "type": "boolean", "description": "Whether identity verification is required" },
    "account_creation_required": { "type": "boolean", "description": "Whether account creation is required" },
    "deadline": { "type": "string", "description": "Deadline for the opportunity" },
    "limitations": { "type": "string", "description": "Known constraints" },
    "metadata": { "type": "object", "description": "Raw source fields" }
  }
}
